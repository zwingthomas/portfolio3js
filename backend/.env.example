# GCP project id that owns the Firestore database.
FIRESTORE_PROJECT=your-gcp-project-id

# Firestore collection that holds ghost docs.
GHOSTS_COLLECTION=ghosts

# Comma-separated list of CORS origins allowed to call the API.
ALLOWED_ORIGINS=https://zwingthomas.github.io,http://localhost:5173

# Storage backend: "firestore" (production) or "memory" (local dev, no GCP).
GHOSTS_BACKEND=memory
